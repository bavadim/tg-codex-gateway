# Telegram Bot token
TELEGRAM_BOT_TOKEN=123456:bot-token

# Comma-separated allowlist: user IDs, @usernames, or t.me links
ALLOWED_CHAT_USER_IDS=@your_username,https://t.me/your_group

# Use OpenCode backend
AGENT_BACKEND=opencode

# OpenCode executable from PATH
OPENCODE_BIN=opencode

# Model name exposed by the runtime config created by this gateway
OPENCODE_MODEL=myopenai/gpt-5

# OpenAI-compatible endpoint for OpenCode provider config
OPENAI_API_BASE=https://openai.bavadim.xyz/v1
OPENAI_API_KEY=
