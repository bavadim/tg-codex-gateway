# Telegram bot token от @BotFather
TELEGRAM_BOT_TOKEN=123456:bot-token

# Кто может пользоваться ботом: user IDs, @usernames или t.me links через запятую
ALLOWED_CHAT_USER_IDS=@your_username,https://t.me/your_group

# Режим получения обновлений Telegram: polling или webhook
TELEGRAM_MODE=polling

# Настройки webhook используются только при TELEGRAM_MODE=webhook
TELEGRAM_WEBHOOK_LISTEN=0.0.0.0
TELEGRAM_WEBHOOK_PORT=8080
TELEGRAM_WEBHOOK_PATH=telegram
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=true

# Backend агента
AGENT_BACKEND=opencode

# opencode из PATH
OPENCODE_BIN=opencode

# Имя модели в runtime-конфиге, который собирает gateway
OPENCODE_MODEL=myopenai/gpt-5

# OpenAI-compatible endpoint и ключ для opencode
OPENAI_API_BASE=https://openai.bavadim.xyz/v1
OPENAI_API_KEY=

# Обязательный GitHub token для gh и skill gh-pm.
# Через него gateway работает с issues и GitHub Projects.
# Для classic PAT обычно нужны права repo + project + read:org.
GH_TOKEN=
